## MySQL (used by docker-compose.yml)
## Adminer: http://localhost:8080 — System: MySQL, Server: mysql (pre-filled), DB/user/password below.
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=fundmonitoringnew
MYSQL_USER=fund_user
MYSQL_PASSWORD=change_me_password

## JWT (passed to ASP.NET via environment variables)
JWT_KEY=change_me_to_a_long_random_secret
JWT_ISSUER=fundmonitoring_api
JWT_AUDIENCE=fundmonitoring_client
JWT_EXPIRE_MINUTES=60
